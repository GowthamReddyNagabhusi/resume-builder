# Environment variables for local development
# Copy this file to .env and fill in required values

# Database Configuration
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_password
POSTGRES_DB=resume_builder
DATABASE_URL=postgresql://resume_user:resume_password@localhost:5432/resume_builder

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_NAME="Resume Builder"
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=DEBUG
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# AI Providers (Optional - for AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=mock

# GitHub OAuth (Optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email Configuration (Optional)
EMAIL_ENABLED=False
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# File Storage
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=50
